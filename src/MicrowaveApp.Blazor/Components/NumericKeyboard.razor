<div class="numeric-keyboard">
    @foreach (var number in Numbers)
    {
        <button type="button" class="key-button" @onclick="() => OnKey.InvokeAsync(number.ToString())" disabled="@Disabled">@number</button>
    }
    <button type="button" class="key-button key-muted" @onclick="ClearAsync" disabled="@Disabled">C</button>
    <button type="button" class="key-button" @onclick="ZeroAsync" disabled="@Disabled">0</button>
    <button type="button" class="key-button key-muted" @onclick="BackspaceAsync" disabled="@Disabled">⌫</button>
</div>

@code {
    private static readonly int[] Numbers = [1, 2, 3, 4, 5, 6, 7, 8, 9];

    [Parameter]
    public EventCallback<string> OnKey { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private Task ClearAsync()
    {
        return OnKey.InvokeAsync("clear");
    }

    private Task BackspaceAsync()
    {
        return OnKey.InvokeAsync("backspace");
    }

    private Task ZeroAsync()
    {
        return OnKey.InvokeAsync("0");
    }
}
