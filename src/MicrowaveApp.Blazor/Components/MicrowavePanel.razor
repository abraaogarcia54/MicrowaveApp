@inject IMicrowaveService MicrowaveService
@inject IHeatingProgramService HeatingProgramService
@inject IAuthState AuthState
@implements IDisposable

<section class="microwave-shell">
    <div class="microwave-display">
        <div class="display-row">
            <span>Tempo</span>
            <strong>@DisplayTime</strong>
        </div>
        <div class="display-row">
            <span>Potência</span>
            <strong>@DisplayPower</strong>
        </div>
        @if (selectedProgram is not null)
        {
            <div class="display-row">
                <span>Programa</span>
                <strong>@selectedProgram.Name</strong>
            </div>
        }
        <div class="heating-output">@HeatingOutput</div>
    </div>

    <div class="microwave-controls">
        <div class="program-tabs">
            <div class="program-tab-switcher">
                <button class="@TabClass("preset")" @onclick="@(() => activeTab = "preset")">Predefinidos</button>
                <button class="@TabClass("custom")" @onclick="@(() => activeTab = "custom")">Customizados</button>
            </div>

            @if (activeTab == "preset")
            {
                <HeatingProgramList
                    Programs="PresetPrograms"
                    SelectedProgram="selectedProgram"
                    Disabled="@(!CanUseApi)"
                    OnSelected="SelectProgramAsync"
                    OnCleared="ClearProgramSelectionAsync" />
            }
            else
            {
                <HeatingProgramList
                    Programs="CustomPrograms"
                    SelectedProgram="selectedProgram"
                    Disabled="@(!CanUseApi)"
                    OnSelected="SelectProgramAsync"
                    OnCleared="ClearProgramSelectionAsync" />

                <HeatingProgramForm OnCreated="HandleProgramCreatedAsync" Disabled="@(!CanUseApi)" />
            }
        </div>

        <label class="field">
            <span>Tempo em segundos</span>
            <input @bind="timeInput" @onfocus="() => activeField = InputField.Time" inputmode="numeric" disabled="@(!CanUseApi || IsInputLocked)" />
        </label>

        <label class="field">
            <span>Potência</span>
            <input @bind="powerInput" @onfocus="() => activeField = InputField.Power" inputmode="numeric" disabled="@(!CanUseApi || IsInputLocked)" />
        </label>

        <NumericKeyboard OnKey="HandleKeyboardAsync" Disabled="@(!CanUseApi || IsInputLocked)" />

        <div class="action-row">
            <button type="button" class="primary-action" @onclick="StartAsync" disabled="@(!CanUseApi)">Iniciar</button>
            <button type="button" class="secondary-action" @onclick="PauseOrCancelAsync" disabled="@(!CanUseApi)">Pausar/Cancelar</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="error-message">@errorMessage</p>
        }
    </div>
</section>

@code {
    private enum InputField
    {
        Time,
        Power
    }

    private HeatingSessionResponse? currentSession;
    private IReadOnlyCollection<HeatingProgramResponse> programs = [];
    private HeatingProgramResponse? selectedProgram;
    private string activeTab = "preset";

    private IReadOnlyCollection<HeatingProgramResponse> PresetPrograms => programs.Where(p => p.IsPresent).ToList();
    private IReadOnlyCollection<HeatingProgramResponse> CustomPrograms => programs.Where(p => !p.IsPresent).ToList();
    private CancellationTokenSource? heatingLoopCancellation;
    private string timeInput = string.Empty;
    private string powerInput = string.Empty;
    private string? errorMessage;
    private InputField activeField = InputField.Time;

    private bool IsInputLocked => selectedProgram is not null || currentSession?.Status is HeatingStatus.Heating or HeatingStatus.Paused;
    private bool CanUseApi => AuthState.IsAuthenticated;
    private string DisplayTime => currentSession?.RemainingTimeDisplay ?? FormatInputTime();
    private string DisplayPower => currentSession?.Power.ToString() ?? (string.IsNullOrWhiteSpace(powerInput) ? "10" : powerInput);
    private string HeatingOutput => currentSession?.HeatingString ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AuthState.Changed += HandleAuthStateChanged;
        await AuthState.InitializeAsync();

        if (CanUseApi)
            await LoadProgramsAsync();
    }

    private async Task StartAsync()
    {
        if (!CanUseApi)
        {
            errorMessage = "Autentique-se para executar esta função.";
            return;
        }

        errorMessage = null;

        try
        {
            if (selectedProgram is not null && currentSession?.Status is not HeatingStatus.Heating and not HeatingStatus.Paused)
                currentSession = await MicrowaveService.StartProgramAsync(selectedProgram.Id);
            else
                currentSession = await MicrowaveService.StartAsync(new StartHeatingRequest(ParseNullable(timeInput), ParseNullable(powerInput)));

            SyncInputsFromSession();
            await StartHeatingLoopAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private async Task PauseOrCancelAsync()
    {
        if (!CanUseApi)
        {
            errorMessage = "Autentique-se para executar esta função.";
            return;
        }

        errorMessage = null;

        try
        {
            currentSession = await MicrowaveService.PauseOrCancelAsync();

            if (currentSession is null)
                ClearInputs();
            else
            {
                SyncInputsFromSession();

                if (currentSession.Status != HeatingStatus.Heating)
                    heatingLoopCancellation?.Cancel();
            }
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private async Task HandleKeyboardAsync(string key)
    {
        if (!CanUseApi || IsInputLocked)
            return;

        if (key == "clear")
        {
            ClearInputs();
            return;
        }

        if (key == "backspace")
        {
            if (activeField == InputField.Time && timeInput.Length > 0)
                timeInput = timeInput[..^1];

            if (activeField == InputField.Power && powerInput.Length > 0)
                powerInput = powerInput[..^1];

            return;
        }

        if (activeField == InputField.Time)
            timeInput += key;
        else
            powerInput += key;

        await Task.CompletedTask;
    }

    private Task SelectProgramAsync(HeatingProgramResponse program)
    {
        heatingLoopCancellation?.Cancel();
        selectedProgram = program;
        currentSession = null;
        errorMessage = null;
        timeInput = program.TimeInSeconds.ToString();
        powerInput = program.Power.ToString();

        return Task.CompletedTask;
    }

    private Task ClearProgramSelectionAsync()
    {
        selectedProgram = null;
        ClearInputs();

        return Task.CompletedTask;
    }

    private async Task HandleProgramCreatedAsync(HeatingProgramResponse program)
    {
        programs = await HeatingProgramService.GetAllAsync();
        selectedProgram = program;
        currentSession = null;
        timeInput = program.TimeInSeconds.ToString();
        powerInput = program.Power.ToString();
    }

    private async Task StartHeatingLoopAsync()
    {
        if (currentSession?.Status != HeatingStatus.Heating)
            return;

        heatingLoopCancellation?.Cancel();
        heatingLoopCancellation = new CancellationTokenSource();
        var token = heatingLoopCancellation.Token;

        try
        {
            while (!token.IsCancellationRequested && currentSession?.Status == HeatingStatus.Heating)
            {
                await Task.Delay(TimeSpan.FromSeconds(1), token);
                currentSession = await MicrowaveService.AdvanceAsync(cancellationToken: token);
                SyncInputsFromSession();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void SyncInputsFromSession()
    {
        if (currentSession is null)
            return;

        timeInput = currentSession.TotalTimeInSeconds.ToString();
        powerInput = currentSession.Power.ToString();
    }

    private void ClearInputs()
    {
        heatingLoopCancellation?.Cancel();
        currentSession = null;
        selectedProgram = null;
        timeInput = string.Empty;
        powerInput = string.Empty;
        errorMessage = null;
    }

    private string FormatInputTime()
    {
        var time = ParseNullable(timeInput);

        if (time is null)
            return "0";

        if (time < 60)
            return time.Value.ToString();

        return $"{time / 60}:{time % 60:00}";
    }

    private string TabClass(string tab) =>
        activeTab == tab ? "program-tab program-tab--active" : "program-tab";

    private static int? ParseNullable(string value)
    {
        return int.TryParse(value, out var parsed) ? parsed : null;
    }

    private async Task LoadProgramsAsync()
    {
        try
        {
            programs = await HeatingProgramService.GetAllAsync();
            errorMessage = null;
        }
        catch (Exception exception)
        {
            programs = [];
            errorMessage = exception.Message;
        }
    }

    private void HandleAuthStateChanged()
    {
        _ = InvokeAsync(HandleAuthStateChangedAsync);
    }

    private async Task HandleAuthStateChangedAsync()
    {
        ClearInputs();

        if (CanUseApi)
            await LoadProgramsAsync();
        else
            programs = [];

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthState.Changed -= HandleAuthStateChanged;
        heatingLoopCancellation?.Cancel();
        heatingLoopCancellation?.Dispose();
    }
}
