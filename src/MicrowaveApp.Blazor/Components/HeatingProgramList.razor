<section class="program-list">
    @if (SelectedProgram is not null)
    {
        <div class="program-list-header">
            <button type="button" class="clear-program-button" @onclick="ClearSelectionAsync" disabled="@Disabled">Limpar seleção</button>
        </div>
    }

    <div class="program-grid">
        @foreach (var program in Programs)
        {
            <button
                type="button"
                class="@GetProgramButtonClass(program)"
                @onclick="() => SelectProgramAsync(program)"
                disabled="@Disabled">
                <strong>@program.Name</strong>
                <span>@program.Food</span>
                <small>@FormatTime(program.TimeInSeconds) • Potência @program.Power • @program.HeatingChar</small>
            </button>
        }
    </div>

    @if (SelectedProgram is not null)
    {
        <p class="program-instructions">@SelectedProgram.Instructions</p>
    }
</section>

@code {
    [Parameter]
    public IReadOnlyCollection<HeatingProgramResponse> Programs { get; set; } = [];

    [Parameter]
    public HeatingProgramResponse? SelectedProgram { get; set; }

    [Parameter]
    public EventCallback<HeatingProgramResponse> OnSelected { get; set; }

    [Parameter]
    public EventCallback OnCleared { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private Task SelectProgramAsync(HeatingProgramResponse program)
    {
        if (Disabled)
            return Task.CompletedTask;

        return OnSelected.InvokeAsync(program);
    }

    private Task ClearSelectionAsync()
    {
        if (Disabled)
            return Task.CompletedTask;

        return OnCleared.InvokeAsync();
    }

    private string GetProgramButtonClass(HeatingProgramResponse program)
    {
        return SelectedProgram?.Id == program.Id
            ? GetProgramTypeClass(program, "program-button selected")
            : GetProgramTypeClass(program, "program-button");
    }

    private static string GetProgramTypeClass(HeatingProgramResponse program, string baseClass)
    {
        return program.IsPresent ? baseClass : $"{baseClass} custom-program";
    }

    private static string FormatTime(int totalSeconds)
    {
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;

        return seconds == 0 ? $"{minutes} min" : $"{minutes}:{seconds:00}";
    }
}
